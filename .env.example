# Copy this file to .env.local and fill your real keys.
# Do NOT commit .env.local to Git.

# Optional: deepseek | gemini
VITE_AI_PROVIDER=gemini

VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=google/gemini-2.5-flash
VITE_GEMINI_ENDPOINT=https://openrouter.ai/api/v1
VITE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VITE_GEMINI_IMAGE_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models

# Optional: Remote TTS via OpenRouter
# When VITE_TTS_STRICT_TEXT_SYNC=1, audio is played only if returned transcript
# matches the on-screen text; otherwise it is dropped silently.
VITE_ENABLE_REMOTE_TTS=1
VITE_TTS_STRICT_TEXT_SYNC=1
VITE_TTS_DEBUG=1
VITE_GEMINI_TTS_ENDPOINT=https://openrouter.ai/api/v1
VITE_GEMINI_TTS_MODEL=openai/gpt-audio-mini
VITE_GEMINI_TTS_VOICE=alloy
VITE_GEMINI_TTS_FORMAT=pcm16
